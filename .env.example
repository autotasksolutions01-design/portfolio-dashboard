# Copy this file to .env and fill in the values

# Security — change this to a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars

# Algorithm for JWT
ALGORITHM=HS256

# Token expiry in minutes (default: 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (SQLite, persisted via Docker volume)
DATABASE_URL=sqlite:////data/portfolio.db

# Alpha Vantage free API key — get one at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo

# CoinGecko — no API key needed for free tier
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Port for the frontend (nginx)
PORT=8080
